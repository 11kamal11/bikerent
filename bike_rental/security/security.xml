<odoo>
    <data noupdate="1">
        <record id="group_bike_rental_user" model="res.groups">
            <field name="name">Bike Rental User</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_bike_rental_manager" model="res.groups">
            <field name="name">Bike Rental Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="access_bike_rental_user" model="ir.model.access">
            <field name="name">bike.rental.user.access</field>
            <field name="model_id" ref="model_bike_rental"/>
            <field name="group_id" ref="group_bike_rental_user"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="access_bike_rental_manager" model="ir.model.access">
            <field name="name">bike.rental.manager.access</field>
            <field name="model_id" ref="model_bike_rental"/>
            <field name="group_id" ref="group_bike_rental_manager"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>