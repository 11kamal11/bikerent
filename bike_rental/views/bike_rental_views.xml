<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Minimal tree view to test installation -->
    <record id="view_bike_rental_tree" model="ir.ui.view">
        <field name="name">bike.rental.tree</field>
        <field name="model">bike.rental</field>
        <field name="arch" type="xml">
            <tree string="Bike Rentals">
                <field name="name" string="Bike Name"/>
            </tree>
        </field>
    </record>
    <!-- Minimal action and menu -->
    <record id="action_bike_rental" model="ir.actions.act_window">
        <field name="name">Bike Rentals</field>
        <field name="res_model">bike.rental</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Click to create a new bike rental record.
            </p>
        </field>
    </record>
    <menuitem id="menu_bike_rental_root" name="Bike Rental" sequence="10"/>
    <menuitem id="menu_bike_rental_action" name="Bike Rentals" parent="menu_bike_rental_root" action="action_bike_rental" sequence="20"/>
</odoo>